{
    "compilerOptions": {
        "outDir": "./lib_js",
        "rootDir": "./",
        "composite": false,
        "declaration": false,
        "target": "esnext",
        "module": "esnext",
        "types": ["node"],
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "allowImportingTsExtensions": true,
        "rewriteRelativeImportExtensions": true,
        "noFallthroughCasesInSwitch": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "strict": true,
        "verbatimModuleSyntax": true
    },
    "include": ["create.ts"],
    "exclude": ["node_modules", "lib_js"]
}
